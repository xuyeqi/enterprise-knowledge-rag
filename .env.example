# 这是本地环境变量示例文件，可以安全提交到 Git。
# 第一次运行项目前，把它复制为项目根目录下的 .env，再填写自己的真实密码。
# 不要在本文件中填写真实密码；真实的 .env 已由 .gitignore 排除。

# PostgreSQL 对宿主机开放的地址和端口。
RAG_POSTGRES_HOST=127.0.0.1
RAG_POSTGRES_PORT=5432

# docker-compose.yml 创建 PostgreSQL 时使用的默认用户和数据库名称。
RAG_POSTGRES_USER=rag_user
RAG_POSTGRES_DB=rag_db

# 这里只保留占位符，复制到 .env 后替换为本地数据库的真实密码。
RAG_POSTGRES_PASSWORD=<your-local-db-password>

# 阿里云百炼 API Key。这里只保留占位符，真实 Key 只能写在本地 .env。
DASHSCOPE_API_KEY=<your-dashscope-api-key>

# 百炼 OpenAI 兼容接口地址，以及项目固定使用的文本向量模型和维度。
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
